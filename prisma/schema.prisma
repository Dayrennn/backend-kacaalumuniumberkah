generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id String @id @default(uuid())
    username String @unique
    role Role
    password String
}

enum Role {
    Admin_1
    Admin_2
    Owner
}

model Kategori {
  id String @id @default(uuid())
  namaKategori String 
  status Status @default(Aktif)

  barang Barang[]
}

enum Status {
  Aktif
  Nonaktif
}

model Barang {
  id String @id @default(uuid())
  kategoriId String
  namaBarang String
  kodeBarang String?
  jumlahBarang Int
  status Status @default(Aktif)
  ukuran String

  kategori Kategori @relation(fields: [kategoriId], references: [id])
}