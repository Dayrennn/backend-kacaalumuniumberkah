generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id String @id @default(uuid())
    username String @unique
    role Role
    password String

    mutasi MutasiStok[]
}

enum Role {
    Admin_1
    Admin_2
    Owner
}

model Kategori {
  id String @id @default(uuid())
  namaKategori String 
  status Status @default(Aktif)

  barang Barang[]
}

enum Status {
  Aktif
  Nonaktif
}

enum jenisPenjualan {
  PCS
  Potongan
}

model Barang {
  id String @id @default(uuid())
  kategoriId String
  namaBarang String
  kodeBarang String?
  jumlahBarang Int
  status Status @default(Aktif)
  ukuran String
  harga Int
  jenisPenjualan jenisPenjualan @default(PCS)

  kategori Kategori @relation(fields: [kategoriId], references: [id])
  mutasi MutasiStok[]
  produk ProdukAds[]
}

enum TipeMutasi {
  Masuk
  Keluar
}

model MutasiStok {
  id          String     @id @default(uuid())
  barangId    String
  userId      String
  customer String?
  suplier String?
  tipe        TipeMutasi
  jumlah      Int
  stokSebelum Int
  stokSesudah Int
  keterangan  String?
  panjangCustom Float?  
  lebarCustom   Float?   
  totalHarga    Float?    
  createdAt   DateTime   @default(now())

  barang Barang @relation(fields: [barangId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([barangId, createdAt])
  @@index([tipe])
}

model ProdukAds {
  id String @id @default(uuid())
  barangId String @unique
  produkImageUrl String
  deskripsi String

  barang Barang @relation(fields: [barangId], references: [id])
}